  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-flash-latest"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {}
  },
  "messages": {
